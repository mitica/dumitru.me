{
  "name": "dumitru.me",
  "version": "2.0.0",
  "private": true,
  "description": "dumitru.me rebuilt with Next.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack && node scripts/create-legacy-html-aliases.mjs",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && gh-pages -d out --dotfiles"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "marked": "^13.0.2",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@tailwindcss/postcss": "^4.1.13",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.7.2"
  }
}
